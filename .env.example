POSTGRES_DB=appdb
POSTGRES_USER=appuser
POSTGRES_PASSWORD=apppassword

DATABASE_URL=postgresql://appuser:apppassword@db:5432/appdb

# Optional production connection string (Supabase Postgres).
# If defined, server DB utils will prefer this value.
SUPABASE_DB_URL=

# SSL mode for PostgreSQL client: auto | on | off
# auto: enabled in production and for supabase hosts.
DB_SSL=auto

SESSION_SECRET=change-me
AUTH_SECRET=change-me-too
AUTH_ALLOWED_EMAILS=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_ARTIST_ID=
SPOTIFY_PLAYLIST_IDS=
SPOTIFY_MARKET=US
YOUTUBE_API_KEY=
YOUTUBE_CHANNEL_ID=
SMTP_URL=
NUXT_PUBLIC_SITE_URL=http://localhost:3000
NUXT_SITE_URL=https://example.com
